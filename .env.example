# Optional GitHub token for higher local API rate limits. Never commit a real value.
GITHUB_TOKEN=

# Local generation is enabled only outside the public viewer deployment.
PITCHFLOW_PUBLIC_VIEWER=0

# The required Build Week model. Change only if the official Codex catalog renames it.
PITCHFLOW_CODEX_MODEL=gpt-5.6-sol

# Optional fixed local port used by the one-command launcher.
PITCHFLOW_PORT=3210
