{
  "name": "pitchflow",
  "version": "0.1.0",
  "private": true,
  "description": "Repo-native AI launch studio built with Codex and GPT-5.6 for OpenAI Build Week.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.9.0 <27"
  },
  "scripts": {
    "build": "pnpm --filter @pitchflow/web build",
    "check:all": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "dev": "pnpm --filter @pitchflow/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "pitchflow": "tsx packages/cli/src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "24.10.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "globals": "17.3.0",
    "prettier": "3.8.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vitest": "4.1.10"
  }
}
