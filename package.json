{
  "name": "pitchflow",
  "version": "0.1.0",
  "private": true,
  "description": "Repo-native AI launch studio built with Codex and GPT-5.6 for OpenAI Build Week.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.9.0 <27"
  },
  "scripts": {
    "build": "pnpm --filter @pitchflow/web build",
    "check:all": "pnpm check:static && pnpm verify:secrets && pnpm verify:licenses && pnpm verify:dependencies && pnpm test:e2e",
    "check:static": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "dev": "pnpm --filter @pitchflow/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "pitchflow": "node --disable-warning=DEP0205 --import tsx/esm packages/cli/src/index.ts",
    "smoke:codex": "node --disable-warning=DEP0205 --import tsx/esm scripts/codex-smoke.ts",
    "smoke:github": "node --disable-warning=DEP0205 --import tsx/esm scripts/ingest-smoke.ts",
    "smoke:render": "node --disable-warning=DEP0205 --import tsx/esm scripts/render-smoke.ts",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "verify:bundle": "node --disable-warning=DEP0205 --import tsx/esm scripts/verify-bundle.ts",
    "verify:dependencies": "node --disable-warning=DEP0205 --import tsx/esm scripts/verify-dependencies.ts",
    "verify:licenses": "node --disable-warning=DEP0205 --import tsx/esm scripts/verify-licenses.ts",
    "verify:secrets": "node --disable-warning=DEP0205 --import tsx/esm scripts/verify-secrets.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "globals": "17.3.0",
    "jszip": "3.10.1",
    "lighthouse": "13.4.0",
    "prettier": "3.8.2",
    "sharp": "0.34.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vitest": "4.1.10"
  }
}
